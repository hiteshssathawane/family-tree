{
  "app": {
    "familyName": "The Family Tree",
    "familyNameMarathi": "आपले कुटुंब",
    "tagline": "हमारा परिवार · Our Heritage",
    "defaultLanguage": "en",
    "supportedLanguages": ["en", "mr"]
  },
  "branches": [
    { "id": "sharma", "name": "Sharma (Paternal)", "color": "#4a7c59" },
    { "id": "kulkarni", "name": "Kulkarni (Maternal)", "color": "#c8963e" },
    { "id": "nair", "name": "Nair (In-laws)", "color": "#5c3d1e" }
  ],
  "media": {
    "provider": "cloudflare-r2",
    "r2PublicUrl": "https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com/family-tree",
    "uploadPresetUrl": "REPLACE_WITH_CLOUDFLARE_R2_PUBLIC_BUCKET_URL",
    "maxPhotoSizeMB": 5,
    "allowedTypes": ["image/jpeg", "image/png", "image/webp"]
  },
  "github": {
    "owner": "REPLACE_WITH_YOUR_GITHUB_USERNAME",
    "repo": "family-tree",
    "branch": "main",
    "dataPath": "data/family.json"
  },
  "features": {
    "totp": true,
    "multiLanguage": true,
    "mapView": false,
    "calendarView": true,
    "adminPanel": true,
    "bulkImport": true,
    "gedcomExport": true,
    "pwa": true,
    "watermark": true,
    "printDisabled": true
  },
  "privacy": {
    "guestSeesDeceasedOnly": true,
    "viewerHidesContactInfo": true,
    "viewerHidesFullAddress": true,
    "livingDOBVisibleToViewer": true
  }
}
